# ── Database Connection ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=my_database
DB_USER=my_user
DB_PASSWORD=my_password

# ── Upload Behavior ───────────────────────────────────────────────
DB_SCHEMA=public           # Target schema
DB_IF_EXISTS=replace       # replace | append | fail
DB_CHUNK_SIZE=1000         # Rows per insert batch

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
